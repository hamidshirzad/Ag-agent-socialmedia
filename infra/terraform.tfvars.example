project_id      = "your-gcp-project-id"
region          = "europe-west1"
service_name    = "fourdoorai"
container_image = "gcr.io/your-project/fourdoorai:latest"
app_version     = "1.0.0"
environment     = "staging"

# Copy this file to terraform.tfvars (gitignored) and fill in the real key.
# Alternatively: export TF_VAR_dd_api_key='<key>' before running terraform apply.
dd_api_key = "REPLACE_WITH_REAL_DD_API_KEY"
