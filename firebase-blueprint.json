{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "company": { "type": "string" },
        "niche": { "type": "string" },
        "goals": { "type": "string" },
        "plan": { "type": "string", "enum": ["starter", "pro", "agency"] },
        "subscriptionStatus": { "type": "string" },
        "paypalSubscriptionId": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "socialAccounts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "platform": { "type": "string", "enum": ["linkedin", "x", "meta", "tiktok"] },
              "accessToken": { "type": "string" },
              "username": { "type": "string" },
              "avatarUrl": { "type": "string" },
              "autoReply": { "type": "boolean" },
              "agentEngagement": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["email", "plan"]
    },
    "Post": {
      "title": "Post",
      "description": "Social media content generated by AI",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "campaignId": { "type": "string" },
        "variationId": { "type": "string" },
        "type": { "type": "string", "enum": ["video", "image", "text"] },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "caption": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "posted"] },
        "autoReply": { "type": "boolean" },
        "agentEngagement": { "type": "boolean" },
        "metrics": {
          "type": "object",
          "properties": {
            "views": { "type": "integer" },
            "clicks": { "type": "integer" },
            "engagements": { "type": "integer" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Lead": {
      "title": "Lead",
      "description": "Inbound leads captured by the system",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "source": { "type": "string" },
        "initialMessage": { "type": "string" },
        "score": { "type": "integer" },
        "status": { "type": "string", "enum": ["new", "qualified", "booked", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Interaction log between AI and leads",
      "type": "object",
      "properties": {
        "leadId": { "type": "string" },
        "sender": { "type": "string", "enum": ["ai", "user"] },
        "content": { "type": "string" },
        "intent": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "Campaign": {
      "title": "Campaign",
      "description": "Marketing campaign settings",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "niche": { "type": "string" },
        "goals": { "type": "string" },
        "active": { "type": "boolean" },
        "variations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "description": { "type": "string" },
              "stats": {
                "type": "object",
                "properties": {
                  "conversions": { "type": "integer" },
                  "engagement": { "type": "number" }
                }
              }
            }
          }
        }
      }
    },
    "ScoringRule": {
      "title": "ScoringRule",
      "description": "Rules for calculating lead scores",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "attribute": { "type": "string" },
        "operator": { "type": "string" },
        "value": { "type": "string" },
        "points": { "type": "integer" },
        "isActive": { "type": "boolean" },
        "category": { "type": "string", "enum": ["attribute", "engagement", "crm"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "attribute", "operator", "points"]
    },
    "TeamMember": {
      "title": "TeamMember",
      "description": "Collaborators or invites details in a workspace",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["Manager", "Analyst", "Content Editor"] },
        "status": { "type": "string", "enum": ["Active", "Pending"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "name", "role", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User account documents"
    },
    "/users/{userId}/scoringRules/{ruleId}": {
      "schema": "ScoringRule",
      "description": "Custom lead scoring rules for a user"
    },
    "/users/{userId}/teamMembers/{memberId}": {
      "schema": "TeamMember",
      "description": "Collaborators in a user's workspace"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Individual social media posts"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Captured lead records"
    },
    "/leads/{leadId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Message history for a lead"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Marketing campaigns"
    }
  }
}
